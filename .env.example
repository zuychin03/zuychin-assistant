# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key for server-side writes (required in production)
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini (default chat + embedding provider)
GEMINI_API_KEY=

# Extra chat/embedding providers (OpenAI-compatible). Set the keys for the
# ones you want to use; providers without a key are hidden in the UI.
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=
NVIDIA_NIM_API_KEY=
OPENCODE_ZEN_API_KEY=

# Optional: override the knowledge store's embedding model (default is
# DEFAULT_EMBEDDING in providers.ts). After changing it, re-embed the store:
# npx tsx --env-file=<env> scripts/reembed-knowledge.ts
KNOWLEDGE_EMBEDDING_MODEL=

# Web search (Tavily). Gives the non-Gemini models real-time internet access via
# the search_web tool. Get a free key at https://tavily.com. Gemini ignores this
# and uses its own Google Search grounding.
TAVILY_API_KEY=

# Timezone the assistant uses for "today"/"now" and the date/time it sees on every
# request. Any IANA name (e.g. America/New_York). Defaults to Australia/Sydney.
APP_TIMEZONE=

# Access Control
ACCESS_PASSWORD=

# Discord — a mostly-outbound life-ops dashboard, one channel per purpose.
# DISCORD_CHANNEL_ID is the legacy single channel and the fallback for any
# DISCORD_CH_* / DISCORD_ASK_CHANNEL_ID left unset. Set the per-purpose ids to
# split notifications into dedicated channels. The Gateway bot only holds
# conversations in DISCORD_ASK_CHANNEL_ID.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_ASK_CHANNEL_ID=
DISCORD_CH_BRIEFING=
DISCORD_CH_REMINDERS=
DISCORD_CH_TASKS=
DISCORD_CH_CALENDAR=
DISCORD_CH_BILLS=
DISCORD_CH_COWORKING=
# Opt-in: run-review/system notices stay silent unless this is set.
DISCORD_CH_SYSTEM=

# Telegram — quick conversational chat + occasional improvised nudges
# (initiative). Structured notifications now go to Discord, not here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Slack — agent co-working workspace where Zuychin orchestrates other AI agents.
# SLACK_SIGNING_SECRET verifies inbound events. Posts use SLACK_USER_TOKEN if
# set (mentions read as human-authored, which some agent apps require), else
# SLACK_BOT_TOKEN. SLACK_APP_ID / SLACK_BOT_USER_ID identify Zuychin's own posts
# to break echo loops. SLACK_AGENTS is the co-working roster (JSON array):
# appId/botId match inbound events, mentionId (a Slack user id) is used to
# @mention the agent, e.g.
# [{"label":"cursor","appId":"A123","mentionId":"U456"},{"label":"codex","appId":"A789","mentionId":"U012"}]
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_USER_TOKEN=
SLACK_APP_ID=
SLACK_BOT_USER_ID=
SLACK_COWORKING_CHANNEL_ID=
SLACK_AGENTS=
# Set to 1 to file finished co-working threads into the vault as a decision log.
SLACK_VAULT_INGEST=

# Google OAuth (Calendar + Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Cron
CRON_SECRET=

# Web push (PWA notifications). Generate the key pair with:
# npx web-push generate-vapid-keys
# Both keys unset = push disabled. VAPID_SUBJECT is a mailto: contact for the
# push service (optional, has a baked-in fallback).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Optional: override the voice-reply TTS model
# (default gemini-3.1-flash-tts-preview)
GEMINI_TTS_MODEL=

# Shared MCP server (/api/mcp/mcp). Two bearer tokens: MCP_API_KEY grants
# read + write (search/save/vault/recent), MCP_API_KEY_READONLY grants read
# only. Leave a key empty to disable that access level; both empty = locked.
MCP_API_KEY=
MCP_API_KEY_READONLY=

# Second Brain vault (private GitHub repo as the online Markdown knowledge base).
# Fine-grained PAT scoped to the single private repo with Contents read/write.
# GITHUB_VAULT_REPO is "owner/repo"; branch defaults to main.
GITHUB_VAULT_TOKEN=
GITHUB_VAULT_REPO=
GITHUB_VAULT_BRANCH=
GITHUB_VAULT_WEBHOOK_SECRET=

# Optional local Obsidian vault name used for obsidian:// open links.
# This is public UI metadata, not a path or secret.
NEXT_PUBLIC_OBSIDIAN_VAULT_NAME=
