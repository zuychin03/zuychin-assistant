# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: service-role key for server-side writes (falls back to anon key)
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini (default chat + embedding provider)
GEMINI_API_KEY=

# Extra chat/embedding providers (OpenAI-compatible). Set the keys for the
# ones you want to use; providers without a key are hidden in the UI.
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=
NVIDIA_NIM_API_KEY=
OPENCODE_ZEN_API_KEY=

# Access Control
ACCESS_PASSWORD=

# Discord
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Google OAuth (Calendar + Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Cron
CRON_SECRET=
