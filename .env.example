# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: service-role key for server-side writes (falls back to anon key)
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini (default chat + embedding provider)
GEMINI_API_KEY=

# Extra chat/embedding providers (OpenAI-compatible). Set the keys for the
# ones you want to use; providers without a key are hidden in the UI.
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=
NVIDIA_NIM_API_KEY=
OPENCODE_ZEN_API_KEY=

# Optional: override the knowledge store's embedding model (default is
# DEFAULT_EMBEDDING in providers.ts). After changing it, re-embed the store:
# npx tsx --env-file=<env> scripts/reembed-knowledge.ts
KNOWLEDGE_EMBEDDING_MODEL=

# Web search (Tavily). Gives the non-Gemini models real-time internet access via
# the search_web tool. Get a free key at https://tavily.com. Gemini ignores this
# and uses its own Google Search grounding.
TAVILY_API_KEY=

# Timezone the assistant uses for "today"/"now" and the date/time it sees on every
# request. Any IANA name (e.g. America/New_York). Defaults to Australia/Sydney.
APP_TIMEZONE=

# Access Control
ACCESS_PASSWORD=

# Discord
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Google OAuth (Calendar + Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Cron
CRON_SECRET=

# Web push (PWA notifications). Generate the key pair with:
# npx web-push generate-vapid-keys
# Both keys unset = push disabled. VAPID_SUBJECT is a mailto: contact for the
# push service (optional, has a baked-in fallback).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Optional: override the voice-reply TTS model
# (default gemini-3.1-flash-tts-preview)
GEMINI_TTS_MODEL=

# Shared MCP server (/api/mcp/mcp). Two bearer tokens: MCP_API_KEY grants
# read + write (search/save/vault/recent), MCP_API_KEY_READONLY grants read
# only. Leave a key empty to disable that access level; both empty = locked.
MCP_API_KEY=
MCP_API_KEY_READONLY=

# Second Brain vault (private GitHub repo as the online Markdown knowledge base).
# Fine-grained PAT scoped to the single private repo with Contents read/write.
# GITHUB_VAULT_REPO is "owner/repo"; branch defaults to main.
GITHUB_VAULT_TOKEN=
GITHUB_VAULT_REPO=
GITHUB_VAULT_BRANCH=
GITHUB_VAULT_WEBHOOK_SECRET=

# Optional local Obsidian vault name used for obsidian:// open links.
# This is public UI metadata, not a path or secret.
NEXT_PUBLIC_OBSIDIAN_VAULT_NAME=
